		RayOriginTranslatedWorld, RayDirection,
		 SceneDepth,
		 SceneDepth,
		 SlopeCompareToleranceScale,
		 true,
		 bRayWasClipped);

	bool bHit;
	bool bUncertain;
	float3 DebugOutput;
	CastScreenSpaceRay(
		Texture, Sampler,
		 1.0,
		CreateDefaultCastSettings(),
		Ray,
		Roughness, NumSteps, StepOffset,
		InHZBUvFactorAndInvFactor, bDebugPrint,
		 DebugOutput,
		 OutHitUVz,
		 Level,
		 bHit,
		 bUncertain);

	return bHit;
}

